{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "JobBot Eng Ind vacancy output",
  "type": "object",
  "additionalProperties": false,
  "required": ["vacancies"],
  "properties": {
    "vacancies": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "priority",
          "company",
          "title",
          "location",
          "work_mode",
          "salary",
          "source",
          "url",
          "language",
          "contract_type",
          "core_tech_match",
          "fit_score",
          "status",
          "analysis",
          "recommendation",
          "found_at",
          "source_group",
          "language_risk",
          "salary_likelihood"
        ],
        "properties": {
          "priority": {
            "type": "string",
            "enum": ["A", "A-", "B+", "B", "B-", "C"]
          },
          "company": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "location": {
            "type": "string",
            "minLength": 1
          },
          "work_mode": {
            "type": "string",
            "minLength": 1
          },
          "salary": {
            "type": "string",
            "minLength": 1
          },
          "source": {
            "type": "string",
            "minLength": 1
          },
          "url": {
            "type": "string",
            "minLength": 1
          },
          "language": {
            "type": "string",
            "minLength": 1
          },
          "contract_type": {
            "type": "string",
            "minLength": 1
          },
          "core_tech_match": {
            "type": "string",
            "minLength": 1
          },
          "fit_score": {
            "type": "number",
            "minimum": 1,
            "maximum": 10
          },
          "status": {
            "type": "string",
            "enum": ["NEW", "previously seen"]
          },
          "analysis": {
            "type": "string",
            "minLength": 20
          },
          "recommendation": {
            "type": "string",
            "minLength": 10
          },
          "found_at": {
            "type": "string",
            "minLength": 10
          },
          "source_group": {
            "type": "string",
            "minLength": 1
          },
          "language_risk": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          },
          "salary_likelihood": {
            "type": "string",
            "enum": ["low", "medium", "high", "unknown"]
          }
        }
      }
    }
  }
}
